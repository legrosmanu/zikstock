# Zikstock Backend Environment Variables Template
PORT=3000

# Firestore emulator (local development only)
FIRESTORE_EMULATOR_HOST=localhost:8080
# GCP project ID — any value works against the emulator; must match your real project in production
GCLOUD_PROJECT=zikstock-local

# Google OAuth2 Client ID used by the auth middleware to validate the JWT audience.
# Leave empty for mock development login or provide your GCP Google Client ID.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

FRONTEND_URL=http://localhost:5173
